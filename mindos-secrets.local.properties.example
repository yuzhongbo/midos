# Local-only overrides (copy to mindos-secrets.local.properties, do not commit real secrets).
# Loaded after dist/mindos-windows-server/mindos-secrets.properties by scripts/unix/local/run-local.sh.

# === Recommended defaults for stable local testing ===
# Keep local development deterministic: prefer local model, disable automatic cloud escalation.
MINDOS_LLM_PROFILE=CUSTOM_LOCAL_FIRST
MINDOS_LLM_MODE=LOCAL_FIRST
MINDOS_LLM_PROVIDER=local
MINDOS_LLM_PROVIDER_ENDPOINTS=local:http://localhost:11434/api/chat,qwen:https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
MINDOS_LLM_PROVIDER_MODELS=local:gemma3:1b-it-q4_K_M
MINDOS_DISPATCHER_SEMANTIC_ANALYSIS_LOCAL_ESCALATION_ENABLED=false
MINDOS_DISPATCHER_LOCAL_ESCALATION_ENABLED=false

# === Optional: explicitly blank cloud-only secrets to suppress placeholder noise locally ===
MINDOS_QWEN_KEY=
MINDOS_LLM_PROVIDER_KEYS=

# === Optional: MCP stays empty by default until you have a real endpoint/key ===
MINDOS_SKILLS_MCP_SERVERS=
MINDOS_SKILLS_MCP_SERVER_HEADERS=

# === Optional: enable cloud fallback only when you really need it ===
# MINDOS_QWEN_KEY=sk-xxxx
# MINDOS_LLM_PROVIDER_KEYS=qwen:sk-xxxx
# MINDOS_DISPATCHER_SEMANTIC_ANALYSIS_LOCAL_ESCALATION_ENABLED=true
# MINDOS_DISPATCHER_LOCAL_ESCALATION_ENABLED=true

# === Optional: MCP (single server first for stable debugging) ===
# MINDOS_SKILLS_MCP_SERVERS=bravesearch:https://api.search.brave.com/res/v1/web/search
# MINDOS_SKILLS_MCP_SERVER_HEADERS=bravesearch:X-Subscription-Token=xxxx
# MINDOS_DISPATCHER_SEARCH_ROUTING_BRAVE_FIRST_ENABLED=true

# === Optional: DingTalk stream ===
# MINDOS_IM_DINGTALK_STREAM_CLIENT_ID=
# MINDOS_IM_DINGTALK_STREAM_CLIENT_SECRET=
# MINDOS_IM_DINGTALK_OUTBOUND_ROBOT_CODE=