# Local-only overrides (copy to mindos-secrets.local.properties, do not commit real secrets).
# Loaded after dist/mindos-windows-server/mindos-secrets.properties by scripts/unix/local/run.sh.

# Recommended local preset:
#   LOCAL_QWEN / CUSTOM_LOCAL_FIRST -> local OpenAI-compatible endpoint first, qwen fallback.
MINDOS_MODEL_PRESET=LOCAL_QWEN
MINDOS_LOCAL_LLM_ENDPOINT=http://localhost:11434/api/chat
MINDOS_LOCAL_LLM_MODEL=gemma3:1b-it-q4_K_M

# Optional cloud keys for fallback or quick preset switching.
MINDOS_QWEN_KEY=
MINDOS_QWEN_MODEL=qwen3.6-plus
MINDOS_OPENROUTER_KEY=
MINDOS_DOUBAO_ARK_KEY=
MINDOS_DOUBAO_ENDPOINT_ID=

# Recommended safe defaults.
MINDOS_DISPATCHER_SEMANTIC_ANALYSIS_LOCAL_ESCALATION_ENABLED=false
MINDOS_DISPATCHER_LOCAL_ESCALATION_ENABLED=false

# Preferred search config: one unified source map.
MINDOS_SKILLS_SEARCH_SOURCES=

# Optional generic MCP tools (non-search).
MINDOS_SKILLS_MCP_SERVERS=
MINDOS_SKILLS_MCP_SERVER_HEADERS=

# Examples:
# MINDOS_MODEL_PRESET=QWEN_STABLE
# MINDOS_QWEN_KEY=sk-xxxx
# MINDOS_MODEL_PRESET=OPENROUTER_INTENT
# MINDOS_OPENROUTER_KEY=sk-or-xxxx
# MINDOS_SKILLS_SEARCH_SOURCES=serper:https://google.serper.dev/search;news-url=https://google.serper.dev/news;api-key=xxxx
