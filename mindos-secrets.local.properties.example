# Local-only overrides (copy to mindos-secrets.local.properties, do not commit real secrets).
# Loaded after dist/mindos-windows-server/mindos-secrets.properties by scripts/unix/local/run-local.sh.

# Minimal local-first setup.
MINDOS_LLM_PROFILE=CUSTOM_LOCAL_FIRST
MINDOS_LLM_MODE=LOCAL_FIRST
MINDOS_LLM_PROVIDER=local
MINDOS_LLM_PROVIDER_ENDPOINTS=local:http://localhost:11434/api/chat,qwen:https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
MINDOS_LLM_PROVIDER_MODELS=local:gemma3:1b-it-q4_K_M
MINDOS_DISPATCHER_SEMANTIC_ANALYSIS_LOCAL_ESCALATION_ENABLED=false
MINDOS_DISPATCHER_LOCAL_ESCALATION_ENABLED=false

# Keep cloud-only secrets blank unless you explicitly want local->cloud fallback.
MINDOS_QWEN_KEY=
MINDOS_LLM_PROVIDER_KEYS=

# Preferred search config: one unified source map.
MINDOS_SKILLS_SEARCH_SOURCES=

# Optional generic MCP tools (non-search).
# MINDOS_SKILLS_MCP_SERVERS=
# MINDOS_SKILLS_MCP_SERVER_HEADERS=

# Examples:
# MINDOS_QWEN_KEY=sk-xxxx
# MINDOS_LLM_PROVIDER_KEYS=qwen:sk-xxxx
# MINDOS_SKILLS_SEARCH_SOURCES=serper:https://google.serper.dev/search;news-url=https://google.serper.dev/news;api-key=xxxx
# MINDOS_SKILLS_MCP_SERVERS=qwensearch:https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp
# MINDOS_SKILLS_MCP_SERVER_HEADERS=qwensearch:Authorization=Bearer sk-xxxx
