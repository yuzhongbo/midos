# 发布用覆盖（Release 专用，复制到目标机为 mindos-secrets.release.properties）。
# 注意：脚本 scripts/unix/local/run-release.sh 会进行严格检查，若存在占位符（REPLACE_WITH_*）将导致启动失败。

# === 推荐：发布时的最小云端启动路由（建议） ===
MINDOS_LLM_PROFILE=QWEN_STABLE
MINDOS_LLM_PROVIDER=qwen
MINDOS_LLM_PROVIDER_ENDPOINTS=qwen:https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
MINDOS_QWEN_MODEL=qwen3.5-plus

# === 发布前必须填写（MUST FILL） ===
MINDOS_QWEN_KEY=REPLACE_WITH_QWEN_KEY
MINDOS_LLM_PROVIDER_KEYS=qwen:REPLACE_WITH_QWEN_KEY

# === 推荐的发布默认项（可保持） ===
MINDOS_DISPATCHER_SEMANTIC_ANALYSIS_LOCAL_ESCALATION_ENABLED=false
MINDOS_DISPATCHER_LOCAL_ESCALATION_ENABLED=false

# === 可选集成（没有真实值请留空） ===
MINDOS_SKILLS_MCP_SERVERS=
MINDOS_SKILLS_MCP_SERVER_HEADERS=
MINDOS_IM_DINGTALK_STREAM_CLIENT_ID=
MINDOS_IM_DINGTALK_STREAM_CLIENT_SECRET=
MINDOS_IM_DINGTALK_OUTBOUND_ROBOT_CODE=

# 可选示例（注释仅作参考）：
# MINDOS_SKILLS_MCP_SERVERS=qwensearch:https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp
# MINDOS_SKILLS_MCP_SERVER_HEADERS=qwensearch:Authorization=Bearer sk-xxxx