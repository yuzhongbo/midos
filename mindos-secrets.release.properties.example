# 发布用覆盖（Release 专用，复制到目标机为 mindos-secrets.release.properties）。
# 注意：脚本 scripts/unix/local/run-release.sh 会进行严格检查，若存在占位符（REPLACE_WITH_*）将导致启动失败。

# === 推荐：发布时的最小云端启动路由（建议） ===
MINDOS_LLM_PROFILE=QWEN_STABLE
MINDOS_LLM_PROVIDER=qwen
MINDOS_LLM_PROVIDER_ENDPOINTS=qwen:https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
MINDOS_QWEN_MODEL=qwen3.5-plus

# === 发布前必须填写（MUST FILL） ===
MINDOS_QWEN_KEY=REPLACE_WITH_QWEN_KEY
MINDOS_LLM_PROVIDER_KEYS=qwen:REPLACE_WITH_QWEN_KEY

# === 推荐的发布默认项（可保持） ===
MINDOS_DISPATCHER_SEMANTIC_ANALYSIS_LOCAL_ESCALATION_ENABLED=false
MINDOS_DISPATCHER_LOCAL_ESCALATION_ENABLED=false

# === 可选集成（优先只填统一搜索源；通用 MCP 保持注释按需开启） ===
MINDOS_SKILLS_SEARCH_SOURCES=
# MINDOS_SKILL_NEWS_SEARCH_SEARCH_SOURCES=
# MINDOS_SKILLS_MCP_SERVERS=
# MINDOS_SKILLS_MCP_SERVER_HEADERS=
MINDOS_IM_DINGTALK_STREAM_CLIENT_ID=
MINDOS_IM_DINGTALK_STREAM_CLIENT_SECRET=
MINDOS_IM_DINGTALK_OUTBOUND_ROBOT_CODE=

# === 可选：Serper 搜索 / 新闻接口（google.serper.dev） ===
# MINDOS_SKILLS_MCP_SERPER_ENABLED=true
# MINDOS_SKILLS_MCP_SERPER_ALIAS=serper
# MINDOS_SKILLS_MCP_SERPER_URL=https://google.serper.dev/search
# MINDOS_SKILLS_MCP_SERPER_API_KEY=REPLACE_WITH_SERPER_KEY
# MINDOS_SKILLS_MCP_SERPER_API_KEY_HEADER=X-API-KEY
# Unified source map（推荐，单一配置入口）:
# MINDOS_SKILLS_SEARCH_SOURCES=serper:https://google.serper.dev/search;news-url=https://google.serper.dev/news;api-key=REPLACE_WITH_SERPER_KEY,brave:https://api.search.brave.com/res/v1/web/search;api-key=REPLACE_WITH_BRAVE_KEY;api-key-header=X-Subscription-Token
# Optional: only for news_search.
# MINDOS_SKILL_NEWS_SEARCH_SEARCH_SOURCES=serper:https://google.serper.dev/search;news-url=https://google.serper.dev/news;api-key=REPLACE_WITH_SERPER_KEY
# Advanced MCP shortcuts:
# MINDOS_SKILLS_MCP_BRAVE_ENABLED=true
# MINDOS_SKILLS_MCP_BRAVE_ALIAS=brave
# MINDOS_SKILLS_MCP_BRAVE_URL=https://api.search.brave.com/res/v1/web/search
# MINDOS_SKILLS_MCP_BRAVE_API_KEY=REPLACE_WITH_BRAVE_KEY
# MINDOS_SKILLS_MCP_BRAVE_API_KEY_HEADER=X-Subscription-Token
# MINDOS_SKILLS_MCP_SERPER_ENABLED=true
# MINDOS_SKILLS_MCP_SERPER_ALIAS=serper
# MINDOS_SKILLS_MCP_SERPER_URL=https://google.serper.dev/search
# MINDOS_SKILLS_MCP_SERPER_API_KEY=REPLACE_WITH_SERPER_KEY
# MINDOS_SKILLS_MCP_SERPER_API_KEY_HEADER=X-API-KEY
# Legacy per-source Serper keys (compatibility fallback only):
# MINDOS_SKILL_NEWS_SEARCH_SERPER_ENABLED=true
# MINDOS_SKILL_NEWS_SEARCH_SERPER_NEWS_URL=https://google.serper.dev/news
# MINDOS_SKILL_NEWS_SEARCH_SERPER_SEARCH_URL=https://google.serper.dev/search
# MINDOS_SKILL_NEWS_SEARCH_SERPER_API_KEY=REPLACE_WITH_SERPER_KEY

# 可选示例（注释仅作参考）：
# MINDOS_SKILLS_MCP_SERVERS=qwensearch:https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp
# MINDOS_SKILLS_MCP_SERVER_HEADERS=qwensearch:Authorization=Bearer sk-xxxx